<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ title }} — {{ site.name }}</title>
  <meta name="description" content="{{ description or site.description }}">
  <link rel="canonical" href="{{ site.url }}{{ page.url }}">
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="{{ site.name }}">
  <meta property="og:title" content="{{ title }} — {{ site.name }}">
  <meta property="og:description" content="{{ description or site.description }}">
  <meta property="og:url" content="{{ site.url }}{{ page.url }}">
  <meta property="og:image" content="{{ site.url }}/assets/og-image.png">
  <meta property="og:image:width" content="1024">
  <meta property="og:image:height" content="1024">
  <meta property="og:image:alt" content="Integritas Civica logo">
  <meta name="twitter:card" content="summary">
  <link rel="icon" type="image/svg+xml" href="/assets/ic-logo.svg">
  <link rel="apple-touch-icon" href="/assets/apple-touch-icon.png">
  <link rel="stylesheet" href="/css/style.css">
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Organization",
        "@id": "{{ site.url }}/#organization",
        "name": "{{ site.name }}",
        "url": "{{ site.url }}",
        "description": "{{ site.description }}",
        "sameAs": {{ site.social | nonEmptyValues | dump | safe }}
      },
      {
        "@type": "WebSite",
        "@id": "{{ site.url }}/#website",
        "url": "{{ site.url }}",
        "name": "{{ site.name }}",
        "publisher": {
          "@id": "{{ site.url }}/#organization"
        }
      },
      {
        "@type": "WebPage",
        "@id": "{{ site.url }}{{ page.url }}",
        "url": "{{ site.url }}{{ page.url }}",
        "name": "{{ title }}",
        "description": "{{ description or site.description }}",
        "isPartOf": {
          "@id": "{{ site.url }}/#website"
        }
      }
    ]
  }
  </script>
  <!-- Privacy-friendly analytics by Plausible -->
  <script async src="https://plausible.io/js/pa-JjbZVllR3vOXRaISKbUdY.js"></script>
  <script>
    window.plausible=window.plausible||function(){(plausible.q=plausible.q||[]).push(arguments)},plausible.init=plausible.init||function(i){plausible.o=i||{}};
    plausible.init()
  </script>
</head>
<body>
  <a class="skip-link" href="#main">Skip to content</a>

  <header>
    <div class="header-inner">
      <a href="/" class="site-title">
        <img src="/assets/ic-logo.svg" alt="" class="site-logo" width="32" height="32">
        <span>{{ site.name }}</span>
      </a>
      <nav aria-label="Main navigation">
        <ul>
          {%- for item in site.nav %}
          <li><a href="{{ item.url }}"{% if page.url == item.url %} aria-current="page"{% endif %}>{{ item.text }}</a></li>
          {%- endfor %}
        </ul>
      </nav>
    </div>
  </header>

  <main id="main">
    <article>
      {{ content | safe }}
    </article>
  </main>

  <footer>
    <div class="footer-inner">
      <p>&copy; 2026 {{ site.name }}. All rights reserved.</p>
      <p><a href="/privacy/">Privacy Policy</a></p>
    </div>
  </footer>
</body>
</html>
